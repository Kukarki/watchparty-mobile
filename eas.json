{
  "cli": {
    "version": ">= 20.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "developmentClient": false,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://sandipwatch7.dedyn.io/api/v1",
        "EXPO_PUBLIC_SOCKET_URL": "https://sandipwatch7.dedyn.io",
        "EXPO_PUBLIC_AVATAR_URL": "https://sandipwatch7.dedyn.io/api/v1/avatar-system"
      }
    },
    "production": {
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}
